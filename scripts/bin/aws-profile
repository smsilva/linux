#!/bin/bash
this_script_path="$(realpath ${0})"
this_script_directory="${this_script_path%/*}"

PATH="${this_script_directory}:${PATH}"

aws_config_file="${HOME}/.aws/config"

while IFS=' = ' read -r key value; do
  [[ -z "${key}" ]] && continue
  case "${key}" in
    sso_session)    sso_session="${value}" ;;
    sso_account_id) sso_account_id="${value}" ;;
    sso_role_name)  sso_role_name="${value}" ;;
    region)         region="${value}" ;;
  esac
done < <(awk '/^\[default\]/{f=1;next} /^\[/{f=0} f && NF{print}' "${aws_config_file}")

cat <<EOF
sso_session.......: ${sso_session}
sso_account_id....: ${sso_account_id}
sso_role_name.....: ${sso_role_name}
region............: ${region}
EOF

echo ""

if identity=$(aws sts get-caller-identity --output text --query '[UserId,Account,Arn]' 2>&1); then
  read -r user_id account arn <<< "${identity}"
  cat <<EOF
UserId..: ${user_id}
Account.: ${account}
Arn.....: ${arn}
EOF
else
  echo "sts get-caller-identity: ${identity}"
fi
