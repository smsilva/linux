#!/usr/bin/env bash
# Layout: [ location ] ▶ [ branch  git-status ] ▶ [ ctx% ] ▶ [ ◔ time ] ▶ [ model ] ▶ [ ∑ tokens ]

input=$(cat)

# --- Configuration ---

# Fixed segment backgrounds (256-color)
section_location_background_color=31 # dark blue
section_branch_background_color=236  # #303030
section_model_background_color=238   # #444444
section_tokens_background_color=244  # #808080, lighter than model

# Context window thresholds (percentage)
ctx_threshold_critical=85
ctx_threshold_warning=60

# Session time thresholds (seconds)
section_sessiontime_seconds_threshold_critical=$(( 60 * 60 ))
section_sessiontime_seconds_threshold_warning=$(( 45 * 60 ))
section_sessiontime_seconds_threshold_caution=$(( 30 * 60 ))

# --- Git: repo name, folder, branch, status indicators ---
current_dir=$(echo "$input" | jq --raw-output '.workspace.current_dir // ""')
project_dir=$(echo "$input" | jq --raw-output '.workspace.project_dir // ""')

if [ -n "$project_dir" ]; then
  repo_name=$(basename "$project_dir")
else
  repo_name=$(basename "$current_dir")
fi

if [ -n "$project_dir" ] && [ "$current_dir" != "$project_dir" ]; then
  rel_folder="${current_dir#"$project_dir"/}"
  location="${repo_name}/${rel_folder}"
else
  location="${repo_name}"
fi

git_root="${project_dir:-$current_dir}"
git_branch=$(git --no-optional-locks --git-dir="${git_root}/.git" \
  rev-parse --abbrev-ref HEAD 2>/dev/null || true)
if [ -z "$git_branch" ] && [ -n "$current_dir" ]; then
  git_branch=$(git --no-optional-locks -C "$current_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
fi

if [ -n "$git_branch" ]; then
  # --bg restores segment bg after each color reset inside the indicators string
  git_indicators=$(git-status-indicators --dir "$git_root" --color --bg "${section_branch_background_color}")
  if [ -n "$git_indicators" ]; then
    section_branch_foreground_color='\033[38;5;247m'  # gray  — dirty
  else
    section_branch_foreground_color='\033[38;5;2m'    # green — clean
  fi
  branch_str=$(printf "${section_branch_foreground_color} \ue0a0 ${git_branch}\033[0m\033[48;5;${section_branch_background_color}m")
fi

# --- Context window ---
used_pct=$(echo "$input" | jq --raw-output '.context_window.used_percentage // 0')
used_int=$(printf '%.0f' "$used_pct")

if   [ "$used_int" -ge "${ctx_threshold_critical}" ]; then section_ctx_background_color=1; section_ctx_foreground_color='\033[30m'
elif [ "$used_int" -ge "${ctx_threshold_warning}" ];  then section_ctx_background_color=3; section_ctx_foreground_color='\033[30m'
else                                                       section_ctx_background_color=2; section_ctx_foreground_color='\033[30m'
fi
ctx_display=$(printf "${section_ctx_foreground_color} ≡ %d%% " "$used_int")

# --- Session time ---
time_str=$(process-uptime --name claude --format human)
elapsed_sec=$(process-uptime --name claude --format seconds)

if   [ "$elapsed_sec" -ge "${section_sessiontime_seconds_threshold_critical}" ]; then section_time_background_color=88;  section_time_foreground_color='\033[38;5;15m'  # white on bordeaux
elif [ "$elapsed_sec" -ge "${section_sessiontime_seconds_threshold_warning}" ];  then section_time_background_color=215; section_time_foreground_color='\033[30m'        # black on orange
elif [ "$elapsed_sec" -ge "${section_sessiontime_seconds_threshold_caution}" ];  then section_time_background_color=221; section_time_foreground_color='\033[30m'        # black on amber
else                                                           section_time_background_color=114; section_time_foreground_color='\033[30m'        # black on green
fi

# --- Model ---
model=$(echo "$input" | jq --raw-output '.model.display_name // "N/A"')

# --- Total tokens ---
total_input=$(echo "$input" | jq -r '.context_window.total_input_tokens // 0')
total_output=$(echo "$input" | jq -r '.context_window.total_output_tokens // 0')
total_tokens=$(( total_input + total_output ))
if [ "$total_tokens" -ge 1000 ]; then
  tokens_display="$(( total_tokens / 1000 ))k"
else
  tokens_display="${total_tokens}"
fi

# --- Assemble segments with powerline separators ---
# Each separator: fg=<current bg> bg=<next bg> → filled-triangle transition
sep=$'\ue0b0'

printf "\033[48;5;${section_location_background_color}m\033[38;5;0m\033[1m %s \033[22m"                                    "$location"        # seg 1: location
if [ -n "$git_branch" ]; then
  printf "\033[38;5;${section_location_background_color}m\033[48;5;${section_branch_background_color}m%s"                  "$sep"             # ▶ location → branch
  printf "\033[48;5;${section_branch_background_color}m%s "                                                                "$branch_str"      # seg 2: branch
  [ -n "$git_indicators" ] && printf "\033[48;5;${section_branch_background_color}m%s "                                    "$git_indicators"  # seg 2: git status
  printf "\033[38;5;${section_branch_background_color}m\033[48;5;${section_ctx_background_color}m%s"                       "$sep"             # ▶ branch → ctx
else
  printf "\033[38;5;${section_location_background_color}m\033[48;5;${section_ctx_background_color}m%s"                     "$sep"             # ▶ location → ctx (no git repo)
fi
printf "\033[48;5;${section_ctx_background_color}m%s"                                                                      "$ctx_display"     # seg 3: ctx %
printf "\033[38;5;${section_ctx_background_color}m\033[48;5;${section_time_background_color}m%s"                           "$sep"             # ▶ ctx → time
printf "\033[48;5;${section_time_background_color}m${section_time_foreground_color} ◔ %s "                                 "$time_str"        # seg 4: time
printf "\033[38;5;${section_time_background_color}m\033[48;5;${section_model_background_color}m%s"                         "$sep"             # ▶ time → model
printf "\033[48;5;${section_model_background_color}m\033[38;5;247m %s "                                                    "$model"           # seg 5: model
printf "\033[38;5;${section_model_background_color}m\033[48;5;${section_tokens_background_color}m%s"                       "$sep"             # ▶ model → tokens
printf "\033[48;5;${section_tokens_background_color}m\033[30m ∑ %s "                                                       "$tokens_display"  # seg 6: total tokens
printf "\033[0m\033[38;5;${section_tokens_background_color}m%s\033[0m"                                                     "$sep"             # trailing ▶
