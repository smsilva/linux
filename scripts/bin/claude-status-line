#!/usr/bin/env bash
# Claude Code statusline script
# Layout: repo/folder [branch] | ctx bar | model

input=$(cat)

# --- Colors ---
YELLOW='\033[33m'
RED='\033[31m'
BRIGHT_GREEN='\033[92m'
CYAN_BRIGHT='\033[96m'

# --- Git repo name + current folder + branch ---
current_dir=$(echo "$input" | jq --raw-output '.workspace.current_dir // ""')
project_dir=$(echo "$input" | jq --raw-output '.workspace.project_dir // ""')

# Repo name: basename of the project/git root
if [ -n "$project_dir" ]; then
  repo_name=$(basename "$project_dir")
else
  repo_name=$(basename "$current_dir")
fi

# Current folder relative to repo root (or just basename when at root)
if [ -n "$project_dir" ] && [ "$current_dir" != "$project_dir" ]; then
  rel_folder="${current_dir#"$project_dir"/}"
  location="${repo_name}/${rel_folder}"
else
  location="${repo_name}"
fi

# Git branch
git_root="${project_dir:-$current_dir}"
git_branch=$(git --no-optional-locks --git-dir="${git_root}/.git" \
  rev-parse --abbrev-ref HEAD 2>/dev/null || true)
if [ -z "$git_branch" ] && [ -n "$current_dir" ]; then
  git_branch=$(git --no-optional-locks -C "$current_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
fi

# Git status indicators (--bg 236 restores segment bg after each color reset)
git_indicators=$(git-status-indicators --dir "$git_root" --color --bg 236)

if [ -n "$git_branch" ]; then
  if [ -n "$git_indicators" ]; then
    branch_color='\033[38;5;247m'  # gray8  — dirty
  else
    branch_color='\033[38;5;2m'    # green  — clean
  fi
  branch_str=$(printf "${branch_color} \ue0a0 ${git_branch}\033[0m\033[48;5;236m")
fi

# --- Context window progress bar ---
used_pct=$(echo "$input" | jq --raw-output '.context_window.used_percentage // 0')
used_int=$(printf '%.0f' "$used_pct")

if   [ "$used_int" -ge 90 ]; then bar_bg_num=1
elif [ "$used_int" -ge 70 ]; then bar_bg_num=3
else                               bar_bg_num=2
fi

# --- Elapsed session time ---
time_str=$(process-uptime --name claude --format human)
elapsed_sec=$(process-uptime --name claude --format seconds)

elapsed_min=$(( elapsed_sec / 60 ))
if   [ "$elapsed_min" -ge 90 ]; then time_color="$RED"
elif [ "$elapsed_min" -ge 60 ]; then time_color="$YELLOW"
elif [ "$elapsed_min" -ge 30 ]; then time_color="$CYAN_BRIGHT"
else                                  time_color="$BRIGHT_GREEN"
fi

# --- Model ---
model=$(echo "$input" | jq --raw-output '.model.display_name // "N/A"')

# --- Assemble with powerline separators ---
# Backgrounds: location=31 (darkblue), branch=236, ctx=dynamic (1/3/2), time=236, model=238
# Separator uses fg=current_bg → bg=next_bg to create the powerline transition.
sep=$'\ue0b0'

printf "\033[48;5;31m\033[38;5;0m\033[1m %s \033[22m"    "$location"         # seg 1: location (bg=31)
printf "\033[38;5;31m\033[48;5;236m%s"                    "$sep"             # 31 → 236
[ -n "$branch_str" ] && printf "\033[48;5;236m%s "       "$branch_str"      # seg 2: branch (bg=236)
[ -n "$git_indicators" ] && printf "\033[48;5;236m%s "   "$git_indicators"  # seg 2: git indicators (bg=236)
printf "\033[38;5;236m\033[48;5;${bar_bg_num}m%s"              "$sep"             # 236 → bar
printf "\033[48;5;${bar_bg_num}m\033[38;5;0m ≡ %d%% "                           "$used_int"                          # seg 3: ctx % (bg=dynamic color)
printf "\033[38;5;${bar_bg_num}m\033[48;5;236m%s"             "$sep"             # bar → 236
printf "\033[48;5;236m ${time_color}◔ %s "          "$time_str"         # seg 4: time (bg=236)
printf "\033[38;5;236m\033[48;5;238m%s"             "$sep"              # 236 → 238
printf "\033[48;5;238m\033[38;5;247m %s "           "$model"            # seg 5: model (bg=238)
printf "\033[0m\033[38;5;238m%s\033[0m"             "$sep"              # trailing sep (fg=238 on default bg)
