#!/bin/bash
this_script_path="$(realpath ${0})"
this_script_name="${this_script_path##*/}"
this_script_directory="${this_script_path%/*}"

PATH="${this_script_directory}:${PATH}"

show_usage() {
  cat <<EOF

  Returns elapsed time since a named process started, by walking the
  process tree from the caller upward until a process with the given
  name is found.

  Session timestamps are stored in ~/.local/share/process-uptime/.
  Files older than 24h are cleaned up automatically.

    Options:

      -h,  --help    Show this help
      -n,  --name    Process name to look for in the process tree (required)
      -f,  --format  Output format: human (default), human-short, seconds, hms

    Examples:

      ${this_script_name} --name claude

      ${this_script_name} --name claude --format seconds

      ${this_script_name} --name bash --format hms

EOF
}

while [[ "${1}" =~ ^- && ! "${1}" == "--" ]]; do
  case $1 in
    -h | --help )
      show_usage
      exit 0
      ;;

    -n | --name )
      shift
      process_name="${1}"
      ;;

    -f | --format )
      shift
      format="${1}"
      ;;

    * )
      echo "Invalid option: ${1}"
      show_usage
      exit 1
      ;;

  esac
  shift
done

if [[ "${1}" == '--' ]]; then shift; fi

format="${format:-human}"

if [[ -z "${process_name}" ]]; then
  echo "Error: --name is required"
  show_usage
  exit 1
fi

# --- Walk process tree looking for the named process ---
pid=$$
session_key="${PPID}"
while [[ "${pid}" -gt 1 ]]; do
  comm=$(cat /proc/${pid}/comm 2>/dev/null || true)
  if [[ "${comm}" == "${process_name}" ]]; then
    session_key=${pid}
    break
  fi
  pid=$(awk '/^PPid:/{print $2}' /proc/${pid}/status 2>/dev/null || echo 1)
done

session_dir="${HOME}/.local/share/process-uptime"
session_file="${session_dir}/${process_name}_${session_key}"

mkdir --parents "${session_dir}"

if [[ ! -f "${session_file}" ]]; then
  date +%s > "${session_file}"
  find "${session_dir}" -name "${process_name}_*" -mmin +1440 -delete 2>/dev/null || true
fi

session_start=$(cat "${session_file}" 2>/dev/null || date +%s)
now=$(date +%s)
elapsed=$(( now - session_start ))

hours=$(( elapsed / 3600 ))
mins=$(( (elapsed % 3600) / 60 ))
secs=$(( elapsed % 60 ))

case "${format}" in
  seconds )
    echo "${elapsed}"
    ;;

  hms )
    printf "%d %d %d\n" "${hours}" "${mins}" "${secs}"
    ;;

  human )
    if [[ "${hours}" -gt 0 ]]; then
      printf "%dh%02dm%02ds\n" "${hours}" "${mins}" "${secs}"
    else
      printf "%02dm%02ds\n" "${mins}" "${secs}"
    fi
    ;;

  human-short )
    if [[ "${hours}" -gt 0 ]]; then
      printf "%dh%02dm\n" "${hours}" "${mins}"
    else
      printf "%02dm\n" "${mins}"
    fi
    ;;

  * )
    echo "Invalid format: ${format}"
    show_usage
    exit 1
    ;;

esac
