#!/bin/bash
image_id="${1}"

list_docker_images() {
  docker image list --format "table {{.Repository}}:{{.Tag}}\t{{.ID}}"
}

if [[ -z "${image_id}" ]]; then
  image_id=$(list_docker_images | sed 1d | sort | fzf | awk '{ print $2 }')
fi

if [[ -z "${image_id}" ]]; then
  docker image ls
else
  docker image rm -f "${image_id}"
  echo ""
  docker image ls
fi
