{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "play service-logout",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "play service-login",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "claude-yaml-validator",
            "statusMessage": "Validating YAML..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/silvios/.claude/statusline.sh",
    "refreshInterval": 5
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true
  },
  "awaySummaryEnabled": false,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "voiceEnabled": true,
  "fileCheckpointingEnabled": false,
  "agentPushNotifEnabled": true
}
