#!/usr/bin/env bash
set -euo pipefail

OLLAMA_API_URL="${OLLAMA_API_URL:-http://localhost:11434}"
MODEL_ALIAS="${OLLAMA_MODEL_ALIAS:-qwen3.5-9b-custom}"
PROMPT="${1:-Responda em uma frase: qual é a capital do Brasil?}"

echo "Testando modelo '${MODEL_ALIAS}' em ${OLLAMA_API_URL}..."
echo "Prompt: ${PROMPT}"
echo ""

curl --silent --fail \
  --request POST \
  "${OLLAMA_API_URL}/api/generate" \
  --header "Content-Type: application/json" \
  --data "$(printf '{"model":"%s","prompt":"%s","stream":false}' "${MODEL_ALIAS}" "${PROMPT}")" \
  | python3 -c "
import sys, json
data = json.load(sys.stdin)
print('Resposta:', data.get('response', '').strip())
print()
print(f'Tokens gerados : {data.get(\"eval_count\", \"N/A\")}')
print(f'Tempo total    : {data.get(\"total_duration\", 0) // 1_000_000} ms')
"
