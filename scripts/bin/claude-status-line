#!/usr/bin/env bash
# Claude Code statusline script
# Layout: repo/folder [branch] | ctx bar | model

input=$(cat)

# --- Colors ---
CYAN='\033[36m'
GREEN='\033[32m'
YELLOW='\033[33m'
RED='\033[31m'
BRIGHT_GREEN='\033[92m'
CYAN_BRIGHT='\033[96m'
RESET='\033[0m'

# --- Git repo name + current folder + branch ---
current_dir=$(echo "$input" | jq --raw-output '.workspace.current_dir // ""')
project_dir=$(echo "$input" | jq --raw-output '.workspace.project_dir // ""')

# Repo name: basename of the project/git root
if [ -n "$project_dir" ]; then
  repo_name=$(basename "$project_dir")
else
  repo_name=$(basename "$current_dir")
fi

# Current folder relative to repo root (or just basename when at root)
if [ -n "$project_dir" ] && [ "$current_dir" != "$project_dir" ]; then
  rel_folder="${current_dir#"$project_dir"/}"
  location="${repo_name}/${rel_folder}"
else
  location="${repo_name}"
fi

# Git branch
git_root="${project_dir:-$current_dir}"
git_branch=$(git --no-optional-locks --git-dir="${git_root}/.git" \
  rev-parse --abbrev-ref HEAD 2>/dev/null || true)
if [ -z "$git_branch" ] && [ -n "$current_dir" ]; then
  git_branch=$(git --no-optional-locks -C "$current_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
fi

# Git status indicators (--bg 0 restores segment bg after each color reset)
git_indicators=$(git-status-indicators --dir "$git_root" --color --bg 0)

if [ -n "$git_branch" ]; then
  if [ -n "$git_indicators" ]; then
    branch_color='\033[38;5;247m'  # gray8  — gitstatus_branch_dirty
  else
    branch_color='\033[38;5;2m'    # green  — gitstatus_branch_clean
  fi
  # Reset restores seg1 background (0 = black) instead of clearing it entirely
  branch_str=$(printf "${branch_color}\ue0a0 ${git_branch}\033[0m\033[48;5;0m")
  location_str="${location} ${branch_str}${git_indicators:+ ${git_indicators}}"
else
  location_str="${location}"
fi

# --- Context window progress bar ---
used_pct=$(echo "$input" | jq --raw-output '.context_window.used_percentage // 0')
used_int=$(printf '%.0f' "$used_pct")

bar_width=10
filled=$(( used_int * bar_width / 100 ))
empty=$(( bar_width - filled ))

fill=$(printf '%*s' "$filled" '')
pad=$(printf '%*s' "$empty" '')
bar="${fill// /█}${pad// /░}"

if [ "$used_int" -ge 90 ]; then
  bar_color="$RED"
elif [ "$used_int" -ge 70 ]; then
  bar_color="$YELLOW"
else
  bar_color="$GREEN"
fi

# --- Elapsed session time ---
time_str=$(process-uptime --name claude --format human)
elapsed_sec=$(process-uptime --name claude --format seconds)

elapsed_min=$(( elapsed_sec / 60 ))
if   [ "$elapsed_min" -ge 90 ]; then time_color="$RED"
elif [ "$elapsed_min" -ge 60 ]; then time_color="$YELLOW"
elif [ "$elapsed_min" -ge 30 ]; then time_color="$CYAN_BRIGHT"
else                                  time_color="$BRIGHT_GREEN"
fi

# --- Model ---
model=$(echo "$input" | jq --raw-output '.model.display_name // "N/A"')

# --- Assemble with powerline separators ---
# Backgrounds: location=0 (black), bar=238, time=236, model=234
# Separator  uses fg=current_bg → bg=next_bg to create the powerline transition.
sep=$'\ue0b0'

printf "\033[48;5;31m\033[38;5;0m\033[1m %s \033[22m"    "$location"         # seg 1: folder name (bg=darkblue, fg=black, bold)
printf "\033[38;5;31m\033[48;5;0m%s"                    "$sep"              # 31 → 0
[ -n "$branch_str" ] && printf "\033[48;5;0m%s "        "$branch_str"       # seg 2: branch (own colors, bg=black)
[ -n "$git_indicators" ] && printf "\033[48;5;0m%s "    "$git_indicators"   # seg 2: git indicators (own colors, bg=black)
printf "\033[38;5;0m\033[48;5;238m%s"                   "$sep"              # 0 → 238
printf "\033[48;5;238m ${bar_color}%s %d%% "        "$bar" "$used_int"  # seg 2: ctx bar (bg=238)
printf "\033[38;5;238m\033[48;5;236m%s"             "$sep"              # 238 → 236
printf "\033[48;5;236m ${time_color}%s "            "$time_str"         # seg 3: time (bg=236)
printf "\033[38;5;236m\033[48;5;234m%s"             "$sep"              # 236 → 234
printf "\033[48;5;234m\033[38;5;247m %s "           "$model"            # seg 4: model (bg=234)
printf "\033[38;5;234m\033[0m%s\033[0m"             "$sep"              # trailing sep
