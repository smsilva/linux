#!/usr/bin/env python3
"""Wait for a CSS selector to appear, then extract text from all matching elements.

Usage:
  wait-and-scrape <url> <selector>

Example:
  wait-and-scrape https://example.com ".product-title"
"""
import asyncio, sys
from playwright.async_api import async_playwright


async def wait_and_scrape(url: str, selector: str):
    async with async_playwright() as p:
        browser = await p.chromium.launch()
        page = await browser.new_page()
        await page.goto(url)
        await page.wait_for_selector(selector, timeout=15000)
        elements = await page.query_selector_all(selector)
        for el in elements:
            print(await el.inner_text())
        await browser.close()


if __name__ == "__main__":
    if len(sys.argv) < 3:
        print(__doc__)
        sys.exit(1)
    asyncio.run(wait_and_scrape(sys.argv[1], sys.argv[2]))
