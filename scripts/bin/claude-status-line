#!/usr/bin/env bash
# Layout: [ location ] ▶ [ branch  git-status ] ▶ [ context% ] ▶ [ ◔ time ] ▶ [ model ] ▶ [ ◈ tokens ]

json_input=$(cat)

# --- Configuration ---

# Fixed segment backgrounds (256-color)
section_location_background_color=31 # dark blue
section_branch_background_color=236  # #303030
section_model_background_color=238   # #444444
section_tokens_background_color=244  # #808080, lighter than model

# Context window thresholds (percentage)
context_threshold_critical=${CLAUDE_CONTEXT_THRESHOLD_CRITICAL:-70}
context_threshold_warning=${CLAUDE_CONTEXT_THRESHOLD_WARNING:-50}

# Session time thresholds (seconds)
session_duration_seconds_threshold_critical=$(( ${CLAUDE_SESSION_DURATION_SECONDS_THRESHOLD_CRITICAL:-35} * 60 ))
session_duration_seconds_threshold_warning=$(( ${CLAUDE_SESSION_DURATION_SECONDS_THRESHOLD_WARNING:-25} * 60 ))
session_duration_seconds_threshold_caution=$(( ${CLAUDE_SESSION_DURATION_SECONDS_THRESHOLD_CAUTION:-15} * 60 ))

# --- Git: repo name, folder, branch, status indicators ---
current_directory=$(echo "${json_input}" | jq --raw-output '.workspace.current_dir // ""')
project_directory=$(echo "${json_input}" | jq --raw-output '.workspace.project_dir // ""')

if [ -n "${project_directory}" ]; then
  project_name=$(basename "${project_directory}")
else
  project_name=$(basename "${current_directory}")
fi

if [ -n "${project_directory}" ] && [ "${current_directory}" != "${project_directory}" ]; then
  relative_subdirectory="${current_directory#"${project_directory}"/}"
  location="${project_name}/${relative_subdirectory}"
else
  location="${project_name}"
fi

git_root="${project_directory:-${current_directory}}"

git_branch=$(
  git \
    --no-optional-locks \
    --git-dir="${git_root}/.git" \
    rev-parse \
    --abbrev-ref HEAD 2>/dev/null || true
)

if [ -z "${git_branch}" ] && [ -n "${current_directory}" ]; then
  git_branch=$(git --no-optional-locks -C "${current_directory}" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
fi

if [ -n "${git_branch}" ]; then
  # --bg restores segment bg after each color reset inside the indicators string
  git_indicators=$(git-status-indicators --dir "${git_root}" --color --bg "${section_branch_background_color}")

  if [ -n "${git_indicators}" ]; then
    section_branch_foreground_color='\033[38;5;247m'  # gray  — dirty
  else
    section_branch_foreground_color='\033[38;5;2m'    # green — clean
  fi
  
  branch_str=$(printf "${section_branch_foreground_color} \ue0a0 ${git_branch}\033[0m\033[48;5;${section_branch_background_color}m")
fi

# --- Context window ---
used_pct=$(echo "${json_input}" | jq --raw-output '.context_window.used_percentage // 0')
used_int=$(printf '%.0f' "$used_pct")

if   [ "$used_int" -ge "${context_threshold_critical}" ]; then
  section_context_background_color=1
  section_context_foreground_color=0
elif [ "$used_int" -ge "${context_threshold_warning}" ]; then
  section_context_background_color=3
  section_context_foreground_color=0
else
  section_context_background_color=2
  section_context_foreground_color=0
fi

# --- Session time ---
session_duration=$(process-uptime --name claude --format human-short)
elapsed_seconds=$(process-uptime --name claude --format seconds)

if   [ "${elapsed_seconds}" -ge "${session_duration_seconds_threshold_critical}" ]; then
  section_time_background_color=88
  section_time_foreground_color=15  # white on bordeaux
elif [ "${elapsed_seconds}" -ge "${session_duration_seconds_threshold_warning}"  ]; then
  section_time_background_color=215
  section_time_foreground_color=0   # black on orange
elif [ "${elapsed_seconds}" -ge "${session_duration_seconds_threshold_caution}"  ]; then
  section_time_background_color=221
  section_time_foreground_color=0   # black on amber
else
  section_time_background_color=114
  section_time_foreground_color=0   # black on green
fi

# --- Model ---
model=$(echo "${json_input}" | jq --raw-output '.model.display_name // "N/A"')

# --- Total tokens ---
total_input=$(echo "${json_input}" | jq --raw-output '.context_window.total_input_tokens // 0')
total_output=$(echo "${json_input}" | jq --raw-output '.context_window.total_output_tokens // 0')
total_tokens=$(( total_input + total_output ))

if [ "${total_tokens}" -ge 1000 ]; then
  tokens_display="$(( total_tokens / 1000 ))k"
else
  tokens_display="${total_tokens}"
fi

# Assemble segments with powerline separators
segment_separator=$'\ue0b0'
_last_segment_background=""

add_segment() {
  local background_color="" args=()

  while [[ $# -gt 0 ]]; do
    case "${1}" in
      --background ) background_color="${2}"; args+=("${1}" "${2}"); shift 2 ;;
      *            ) args+=("${1}");                                 shift   ;;
    esac
  done

  if [ -n "${_last_segment_background}" ] && [ "${_last_segment_background}" != "${background_color}" ]; then
    ansi-text \
      --text "${segment_separator}" \
      --background "${background_color}" \
      --foreground "${_last_segment_background}"
  fi

  ansi-text "${args[@]}"
  _last_segment_background="${background_color}"
}

end_segments() {
  printf "\033[0m\033[38;5;${_last_segment_background}m%s\033[0m" "${segment_separator}"
}

add_segment --text " ${location} " --background "${section_location_background_color}" --foreground 0 --bold

if [ -n "${git_branch}" ]; then
  add_segment --text "${branch_str} "     --background "${section_branch_background_color}"

  [ -n "${git_indicators}" ] && \
  add_segment --text "${git_indicators} " --background "${section_branch_background_color}"
fi

add_segment --text " ≡ ${used_int}% "        --background "${section_context_background_color}" --foreground "${section_context_foreground_color}"
add_segment --text " ◔ ${session_duration} " --background "${section_time_background_color}"    --foreground "${section_time_foreground_color}"
add_segment --text " ✦ ${model} "            --background "${section_model_background_color}"   --foreground 247
add_segment --text " ◈ ${tokens_display} "   --background "${section_tokens_background_color}"  --foreground 0

end_segments
